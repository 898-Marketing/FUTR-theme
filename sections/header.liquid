{% comment %}
Testing Cypress integration
{% endcomment %}

{{ 'mobile-menu-component.min.css' | asset_url | stylesheet_tag: preload: true }}

{% assign overlay_opacity = 100 | minus: section.settings.overlay_opacity %}
{% assign overlay_bg_color = 'rgba(' | append: settings.header-transparent-background.rgba | append: ')' %}
{% assign opaque_color = 'color-mix(in srgb, ' | append: overlay_bg_color | append: ', transparent ' | append: overlay_opacity | append: '%)' %}
{% assign overlay = false %}
{% assign mega_menu_block = section.blocks | where: 'type', 'content' | first %}

{% assign homepage-overlay = false %}
{% if section.settings.overlay_header_homepage and template == 'index' %}
  {% assign homepage-overlay = true %}
{% endif %}

{% assign collection-overlay = false %}
{% if section.settings.overlay_header_other_pages and section.settings.overlay_header_collection and template.name == 'collection' %}
  {% assign collection-overlay = true %}
{% endif %}

{% assign list-collection-overlay = false %}
{% if section.settings.overlay_header_other_pages and section.settings.overlay_header_list_collection and template == 'list-collections' %}
  {% assign list-collection-overlay = true %}
{% endif %}

{% assign contact-overlay = false %}
{% if section.settings.overlay_header_other_pages and section.settings.overlay_header_contact and template == 'page.contact' %}
  {% assign contact-overlay = true %}
{% endif %}

{% assign article-overlay = false %}
{% if section.settings.overlay_header_other_pages and section.settings.overlay_header_article and template.name == 'article' %}
  {% assign article-overlay = true %}
{% endif %}

{% if homepage-overlay
  or collection-overlay
  or list-collection-overlay
  or contact-overlay
  or article-overlay
%}
  {% assign overlay = true %}
{% endif %}

{% capture locale %}
  {% render 'localization-form', show_locale_selector: section.settings.show_locale_selector, show_currency_selector: section.settings.show_currency_selector, show_country_name: section.settings.show_country_name, show_country_flag: section.settings.show_country_flag, show_currency_selector_desktop: section.settings.show_currency_selector_desktop, show_locale_selector_desktop: section.settings.show_locale_selector_desktop %}
{% endcapture %}

{% assign menu_size = linklists[section.settings.main_linklist] | size %}
{% if menu_size == 0 %}
  {% assign site_nav = blank %}
{% else %}
  {% capture site_nav %}
    <div role="navigation" class="js site-header__nav top-links" id="top_links_wrapper">
      <ul class="site-nav nav-link-animated {% if mega_menu_block %} mega-menu-wrapper{% endif %}" id="AccessibleNav">
        {% render 'nav--main', mega_menu: mega_menu_block, logo_position: section.settings.logo-placement %}
      </ul>
    </div>
  {% endcapture %}
{% endif %}

{% capture offers_icon_link %}
  {% liquid 
    assign offers_drawer_icon_color = 'rgba(' | append: section.settings.offers_drawer_icon_color.rgba | append: ')'
  %}
  {% if section.settings.offers_drawer_color_override %}
    {% assign offers_drawer_header_color = offers_drawer_icon_color %}
  {% else %}
    {% assign offers_drawer_header_color = 'currentColor' %}
    <style>
      .offers-drawer__heading svg {
        color: {{ offers_drawer_icon_color }};
      }
    </style>
  {% endif %}
  <div class="offers-drawer-icon-container">
    <a
      href="#"
      class="standalone-icon--wrapper offers-drawer-icon-wrapper js-drawer-open-offers-link"
      aria-controls="OffersDrawer" 
      aria-expanded="false"
      aria-label="{{ 'layout.header.offers_drawer' | t }}"
    >
      {% assign offers_icon = section.settings.offers_drawer_icon | append: '-large' %}
      {% render 'theme-icon', icon: offers_icon, iconColor: offers_drawer_header_color, iconAttributes: 'data-offers-drawer-icon' %}
    </a>
    {% if section.settings.offers_drawer_show_tooltip %}
      <div
        {% unless section.settings.offers_drawer_tooltip_test_mode %}data-offers-drawer-tooltip{% endunless %}
        class="offers-drawer-tooltip thumbnail-radius text-link-animated{% unless section.settings.offers_drawer_tooltip_test_mode %} hide{% endunless %}"
        style="color: rgba({{ section.settings.offers_drawer_tooltip_text_color.rgba }}); --tooltip-background-color: rgba({{ section.settings.offers_drawer_tooltip_background_color.rgba }}); --nav-text-color: rgba({{ section.settings.offers_drawer_tooltip_text_color.rgba }}); --nav-text-hover: rgba({{ section.settings.offers_drawer_tooltip_text_color.rgba }}); --link-border-color: rgba({{ section.settings.offers_drawer_tooltip_text_color.rgba }});"
      >
        {{ section.settings.offers_drawer_tooltip_text }}
      </div>
    {% endif %}
  </div>
{% endcapture %}

{% capture top_links %}
  <ul class="site-header__links top-links--icon-links">
    {% if shop.customer_accounts_enabled %}
      <li>
        {% comment %}
          Shopify account web component (required for storefronts). Kept in its
          existing position (first in the desktop icon row) per the Capital design.
          Renders the customer avatar and account sheet (passwordless / social
          sign-in, orders, profile). The signed-out state reuses the theme's existing
          account icon via the signed-out-avatar slot; the signed-in avatar is rendered
          and controlled by Shopify and can only be styled with the shopify-account CSS
          custom properties (see the section style block below).
          Docs: https://shopify.dev/docs/storefronts/themes/customer-engagement/account-component
        {% endcomment %}
        <shopify-account menu="{{ section.settings.customer_account_menu | default: 'customer-account-main-menu' }}" class="account-button standalone-icon--wrapper">
          <span slot="signed-out-avatar" class="account-button__signed-out">
            {% if section.settings.show_icons %}
              {% render 'theme-icon', icon: 'user-large', iconSize: 20 %}
            {% else %}
              <span class="header--supporting-text">{{ 'layout.header.account' | t }}</span>
            {% endif %}
          </span>
        </shopify-account>
      </li>
    {% endif %}

    {% if section.settings.enable_search %}
      <li>
        <a href="{{ routes.search_url }}" class="search-button standalone-icon--wrapper" aria-label="{{ 'layout.header.search' | t }}">
          {% if section.settings.show_icons %}
            {% render 'theme-icon', icon: 'search-large', iconSize: 20 %}
          {% else %}
            <span class="header--supporting-text">{{ 'layout.header.search' | t }}</span>
          {% endif %}
        </a>
      </li>
    {% endif %}

    {% if section.settings.show_offers_drawer and section.settings.show_icons %}
      <li>
        {{ offers_icon_link }}
      </li>
    {% endif %}

    <li>
      <a 
        href="{{ routes.cart_url }}" 
        class="site-header__cart-toggle{% if settings.cart_type == "drawer" %} js-drawer-open-right-link{% endif %}{% if section.settings.cart_count %} cart-count-enabled {{ section.settings.cart-style }}{% endif %}{% if cart.item_count > 0 %} cart-count-visible{% endif %} standalone-icon--wrapper{% if section.settings.show_icons %} header-icons-enabled{% endif %}"
        aria-controls="CartDrawer" 
        aria-expanded="false" 
        aria-label="{{ 'layout.header.your_cart' | t }}"
      >
        {% if section.settings.show_icons %}
          {% if section.settings.cart-style == 'shopping-bag' %}
            {% render 'theme-icon', icon: 'shopping-bag-large' %}
          {% else %}
            {% render 'theme-icon', icon: 'shopping-cart-large' %}
          {% endif %}
          {% if section.settings.cart_count %}                                                                                                                                          
              <span 
                data-cart-count-indicator
                class="cart-item-count-bubble cart-item-count-header cart-item-count-header--quantity{% if cart.item_count == 0 %} hide{% endif %}"
              >
                {{ cart.item_count }}
              </span>
          {% endif %}
        {% else %}
          <span class="header--supporting-text">
            {{ 'layout.header.your_cart' | t }}
            {% if section.settings.cart_count %}
                <span 
                  data-cart-count-indicator
                  class="cart-item-count-header cart-item-count-header--has-label cart-item-count-header--quantity{% if cart.item_count == 0 %} hide{% endif %}"
                >
                  {{ cart.item_count }}
                </span>
            {% endif %}
          </span>
        {% endif %}
      </a>
    </li>

    {% if section.settings.show_offers_drawer and section.settings.show_icons == false %}
      <li>
        {{ offers_icon_link }}
      </li>
    {% endif %}
  </ul>
{% endcapture %}

{% style %}
  .default-menu-drawer-text-color {
    color: var(--menu-drawer-text-color);
  }

  {% comment %}
    Align the Shopify account web component with the other header icons/labels
    (desktop icon row only). Match the sibling <a> items: inline-flex + centered,
    inheriting line-height (do NOT zero it — that collapses the "Account" text
    label and offsets the signed-in avatar vertically).
  {% endcomment %}
  .top-links--icon-links shopify-account.account-button {
    display: inline-flex;
    align-items: center;
    {% comment %}
      Push the signed-in account sheet down so it clears the header row instead
      of overlapping the menu items. --shopify-account-dialog-position-top is a
      documented CSS custom property on the component; it inherits through the
      shadow boundary. Driven by --header-height-desktop (the live .site-header
      height, set on :root in Header.js) so it tracks the actual header; falls
      back to 100px (the verified-good value) before that JS-set var resolves.
    {% endcomment %}
    --shopify-account-dialog-position-top: var(--header-height-desktop, 100px);
  }

  {% comment %}
    Brand the account sheet with the theme's tokens. These are documented
    top-level CSS custom properties on the component (the avatar/dialog colours,
    radius, fonts etc. are derived from them). Set on the host element directly —
    not :root — so they win over any :host defaults the component ships, and
    applied to every shopify-account instance (desktop header + mobile drawer)
    since this is brand theming, not the desktop-only placement above.
    Each maps to an existing theme variable from css-variables.liquid.
  {% endcomment %}
  shopify-account {
    --shopify-account-color-accent: var(--primary-btn-bg-color);
    --shopify-account-color-background: var(--header-color);
    --shopify-account-color-text: var(--nav-text-color);
    {% comment %}
      Override the colours the component would otherwise auto-derive from the
      three bases above, mapping each to its theme equivalent:
      - accent-hover: the theme's real button hover is a shine animation we can't
        reach inside the shadow DOM, so match the accent (no hover colour shift)
        rather than invent one.
      - accent-text: primary button text colour.
      - border: nav text colour at 25% opacity (mirrors the theme's own
        --border-color, which is body text @ 25%). Always visible and header-
        consistent, rather than the merchant's header border which may be transparent.
      - background-subdued: this is the fill the component paints behind a menu row
        on hover (and other subdued surfaces). When a row is filled the component
        drops its divider borders, so if this matched the sheet bg the hover would be
        invisible and only the dividers would vanish (looks random). Give it a faint
        tint — nav text @ 7% over the header bg — so hover reads as a subtle grey fill
        with the dividers intact (Horizon-style), adapting to light/dark headers.
      - card-background/text: header bg/text (kept the same as the sheet bg so cards
        sit flush — intentional flat look).
      - control-text: header text colour, for legibility on the control.
      NB control-background is intentionally NOT set: the component re-derives it
      inside the shadow DOM (background mixed ~10% with white) and ignores a
      host-level override, so it can't be forced transparent.
    {% endcomment %}
    --shopify-account-color-accent-hover: var(--primary-btn-bg-color);
    --shopify-account-color-accent-text: var(--primary-btn-text-color);
    --shopify-account-color-background-subdued: color-mix(in srgb, var(--nav-text-color) 7%, var(--header-color));
    --shopify-account-color-border: color-mix(in srgb, var(--nav-text-color), transparent 75%);
    --shopify-account-color-card-background: var(--header-color);
    --shopify-account-color-card-text: var(--nav-text-color);
    --shopify-account-color-control-text: var(--nav-text-color);
    --shopify-account-font-body: var(--body-font-stack);
    --shopify-account-font-body-weight: var(--body-font-weight);
    --shopify-account-font-heading: var(--header-font-stack);
    --shopify-account-font-heading-transform: var(--heading-font-case);
    --shopify-account-font-heading-weight: var(--header-font-weight);
    --shopify-account-radius-base: var(--block-border-radius);
    --shopify-account-radius-button: var(--alt-btn-border-radius, 0);
    --shopify-account-radius-dialog: var(--block-border-radius);
    --shopify-account-radius-input: var(--input-border-radius);
    {% comment %}
      Sizing + signed-in avatar colours (default / solid-header state). Pin the account
      button and the signed-in avatar circle to 20px to match the other header icons
      (search/cart render via theme-icon at iconSize: 20). The avatar colours below cover
      every SOLID-header state — non-overlay pages, sticked headers, and overlay headers
      on hover — using the header bg/text. The transparent overlay state is overridden in
      _header.scss (overlay blocks), and mobile is overridden just below.
      NB the avatar background can't be transparent (the component falls back to its
      default blue), which is why the overlay override uses the solid overlay *text*
      colour as the background rather than the (often transparent) overlay background.
    {% endcomment %}
    --shopify-account-avatar-size: 20px;
    --shopify-account-signed-in-avatar-size: 20px;
    --shopify-account-signed-in-avatar-color-background: var(--header-color);
    --shopify-account-signed-in-avatar-color-text: var(--nav-text-color);
  }

  {% comment %}
    Mobile overrides. The rule above maps the sheet's backgrounds/text to the
    desktop header colours (--header-color / --nav-text-color), but on mobile the
    component shows inside the mobile nav drawer, which has its own colour settings.
    Below the mobile-nav breakpoint (989px), re-point only the colour vars that
    derive from header bg/text to the mobile-nav equivalents (--menu-drawer-color /
    --menu-drawer-text-color). Same specificity as the base rule, so source order
    (this comes after) makes it win on mobile. Desktop is untouched. The accent,
    font, radius and sizing vars don't differ by breakpoint, so they're not repeated.
  {% endcomment %}
  @media screen and (max-width: 989px) {
    shopify-account {
      --shopify-account-color-background: var(--menu-drawer-color);
      --shopify-account-color-text: var(--menu-drawer-text-color);
      --shopify-account-color-background-subdued: color-mix(in srgb, var(--menu-drawer-text-color) 7%, var(--menu-drawer-color));
      --shopify-account-color-border: color-mix(in srgb, var(--menu-drawer-text-color), transparent 75%);
      --shopify-account-color-card-background: var(--menu-drawer-color);
      --shopify-account-color-card-text: var(--menu-drawer-text-color);
      --shopify-account-color-control-text: var(--menu-drawer-text-color);
      --shopify-account-signed-in-avatar-color-background: var(--menu-drawer-color);
      --shopify-account-signed-in-avatar-color-text: var(--menu-drawer-text-color);
    }
  }

  {% comment %}
    Overlay-header avatar colours are handled in _header.scss (the overlay-active and
    hover/sticked-revert blocks), reusing the theme's own overlay state selectors.
    Overlay-active uses the solid overlay text colour as the avatar background (the
    background can't be transparent without falling back to the component's blue).
  {% endcomment %}

  {% comment %}
    When the account sheet opens, the component locks scroll with inline
    "overflow: hidden" on <html> (alongside touch-action:none + scrollbar-gutter).
    overflow:hidden on the ROOT element makes the viewport non-scrollable, which
    breaks our position:sticky header: it keeps position:sticky/.sticked but reverts
    to its in-flow document-top position until the sheet closes (desktop only).
    Restore the default so the viewport scrolls again and sticky re-engages. Must be
    "visible", NOT "auto": auto makes <html> its own (content-height, non-scrolling)
    scroll container, so sticky binds to that and still won't stick.
    Scoped via the lock's distinctive "touch-action: none" so our own cart/menu
    drawers (which use plain overflow:hidden) aren't unlocked. Trade-off: the page
    can scroll behind the open sheet, which is acceptable.
    FRAGILE: the html[style*="touch-action: none"] selector is coupled to Shopify's
    internal account-sheet scroll-lock (an undocumented implementation detail). If
    Shopify changes how the sheet locks scroll, this rule may stop matching and the
    sticky header will break again — re-test the sticky header on overlay pages
    (home/collection/article/contact, signed in, scrolled) after any component update.
  {% endcomment %}
  html[style*="touch-action: none"] {
    overflow: visible !important;
  }

  {% if customer %}
    {% comment %} Signed in only: centre Shopify's avatar and drop the icon-wrapper padding {% endcomment %}
    .top-links--icon-links shopify-account.account-button {
      justify-content: center;
      padding: 0 !important;
    }
  {% endif %}

  {% comment %}
    The signed-out-avatar part is an avatar-sized box by default (the docs size it
    to e.g. 64px), which makes the text/icon trigger taller than the plain-text
    Search/Cart links. Reset it to fit its content so heights line up.
  {% endcomment %}
  .top-links--icon-links shopify-account.account-button::part(signed-out-avatar) {
    width: auto;
    height: auto;
    min-width: 0;
    min-height: 0;
    padding: 0;
  }

  {% comment %}
    The slotted signed-out span is inline by default, which adds a baseline/line-box
    gap and makes the trigger taller than the sibling links. Flex it in both the
    text ("Account" label) and icon (svg) variants so it collapses to its content
    height and lines up.
  {% endcomment %}
  .top-links--icon-links .account-button__signed-out:has(.header--supporting-text),
  .top-links--icon-links .account-button__signed-out:has(svg) {
    display: flex;
    align-items: center;
  }

  {% if section.settings.show_locale_selector or section.settings.show_currency_selector %}
    .locale--mobile {
      padding: 15px;
    }
  {% endif %}
{% endstyle %}

<div
  class="header-section--wrapper
    {%- if collection-overlay or homepage-overlay or list-collection-overlay or contact-overlay or article-overlay %} overlay-header-wrapper{% endif -%}
    {%- if collection.image %} collection-image-enabled{% endif -%}
  "
  data-wetheme-section-type="header"
  data-wetheme-section-id="{{ section.id }}"
  data-header-sticky="{{ section.settings.sticky_header }}"
  data-header-reveal-on-scroll="{{ section.settings.reveal_on_scroll }}"
  data-header-overlay="{{ overlay }}"
>
  <div id="NavDrawerOverlay" class="drawer-overlay"></div>
  <div id="NavDrawer" class="drawer drawer--left" inert>

    <div class="mobile-nav-grid-container">
      <div class="mobile-nav__logo-title">
        <div class="mobile-nav__logo-title--inner">
          <a href="#" class="mobile-menu--close-btn standalone-icon--wrapper" aria-label="{{ 'layout.drawers.close_menu' | t }}" role="button">
            {% render 'theme-icon', icon: 'close', iconSize: 20 %}
          </a>
        </div>
      </div>

      <!-- begin mobile-nav -->
      <ul class="mobile-nav mobile-nav--main">
        {% assign menu = linklists[section.settings.main_linklist] %}
        {% for link in menu.links %}
          {% liquid 
            assign link-title = link.title | strip | downcase
            assign is-mega-menu = false

            assign show_first_promo_image = false
            assign show_second_promo_image = false
  
            for block in section.blocks
              if block.settings.show_promo_1_in_mobile_drawer == true and block.settings.mega_image_1
                assign show_first_promo_image = true
              endif

              if block.settings.show_promo_2_in_mobile_drawer == true and block.settings.mega_image_2
                assign show_second_promo_image = true
              endif

              assign block-title = block.settings.mega-menu | strip | downcase
              if block-title == link-title
                if show_first_promo_image == true or show_second_promo_image == true
                  assign is-mega-menu = true
                endif
              endif
            endfor
          %}
          {% if link.links != blank %}
            <li class="mobile-nav__item top-level{% if link.active %} mobile-nav__item--active{% endif %}{% if is-mega-menu %} mega-menu--mobile{% endif %}" aria-haspopup="true">
              <div class="mobile-nav__has-sublist">
                <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
                <div class="mobile-nav__toggle">
                  <button type="button" class="icon-fallback-text mobile-nav__toggle-open standalone-icon--wrapper touch-target icon-no-padding" aria-label="{{ 'cart.general.see_more' | t }}">
                    {% render 'theme-icon', icon: 'arrow-right', iconSize: 16, iconAttributes: 'aria-hidden="true"' %}
                  </button>
                </div>
              </div>
              <ul class="mobile-nav__sublist">
                {% for sub_link in link.links %}
                  {% if sub_link.levels > 0 %}
                    <li class="mobile-nav__item {% if sub_link.active %} mobile-nav__item--active{% endif %}">
                      <div class="mobile-nav__has-sublist">
                        <a href="{{ sub_link.url }}" class="mobile-nav__link">{{ sub_link.title | escape }}</a>
                        <div class="mobile-nav__toggle">
                          <button type="button" class="icon-fallback-text mobile-nav__toggle-open standalone-icon--wrapper touch-target icon-no-padding" name="{{ 'cart.general.see_more' | t }}">
                            {% render 'theme-icon', icon: 'arrow-right', iconSize: 16, iconAttributes: 'aria-hidden="true"' %}
                            <span class="fallback-text">{{ 'cart.general.see_more' | t }}</span>
                          </button>
                        </div>
                      </div>
                      <ul class="mobile-nav__sublist">
                        {% for sub_sub_link in sub_link.links %}
                          <li class="mobile-nav__item">
                            <a href="{{ sub_sub_link.url }}" class="mobile-nav__link">{{ sub_sub_link.title | escape }}</a>
                          </li>
                        {% endfor %}
                      </ul>
                    </li>
                  {% else %}
                    <li class="mobile-nav__item{% if sub_link.active %} mobile-nav__item--active{% endif %}">
                      <a href="{{ sub_link.url }}" class="mobile-nav__link">{{ sub_link.title | escape }}</a>
                    </li>
                  {% endif %}
                {% endfor %}

                {% if is-mega-menu %}
                  <ul class="mobile-promo--block">
                    {% for block in section.blocks %}
  
                      {% liquid
                        assign link-title = link.title | strip | downcase
                        assign block-title = block.settings.mega-menu | strip | downcase

                        assign image_2_stretch = false
                        assign crop_setting_2 = block.settings.image_2_aspect_ratio
                        if crop_setting_2 == "square"
                          assign image_2_crop = "aspect-ratio--square"
                          assign image_2_stretch = true
                        elsif crop_setting_2 == "tall"
                          assign image_2_crop = "aspect-ratio--tall"
                          assign image_2_stretch = true
                        elsif crop_setting_2 == "wide"
                          assign image_2_crop = "aspect-ratio--wide"
                          assign image_2_stretch = true
                        else
                          assign image_2_crop = false
                          assign image_2_stretch = false
                        endif

                        assign first_promo_has_text = false
                        if block.settings.mega_image_header_1 != blank or block.settings.mega_image_subheader_1 != blank
                          assign first_promo_has_text = true
                        endif

                        assign second_promo_has_text = false
                        if block.settings.mega_image_header_2 != blank or block.settings.mega_image_subheader_2 != blank
                          assign second_promo_has_text = true
                        endif
                      %}

                      {% style %}
                        .block-id-{{ block.id }} .overlay-text-on-image-promo-1 {
                          color: rgba({{ block.settings.overlay_text_color_promo_1.rgba }}) !important;
                        }

                        .block-id-{{ block.id }} .overlay-text-on-image-promo-2 {
                          color: rgba({{ block.settings.overlay_text_color_promo_2.rgba }}) !important;
                        }
                      {% endstyle %}
  
                      {% if link-title == block-title %}
                        {% if block.settings.mega_image_1 and block.settings.show_promo_1_in_mobile_drawer %}
                          {% render 'mega-menu-promo-card', 
                            promo_wrapper_classes: "mobile-nav__item",
                            promo_block_id: block.id,
                            promo_img: block.settings.mega_image_1,
                            promo_img_crop: block.settings.image_1_aspect_ratio,
                            promo_text_overlay: block.settings.overlay_text_on_image_promo_1,
                            promo_text_heading: block.settings.mega_image_header_1,
                            promo_text_subheading: block.settings.mega_image_subheader_1,
                            promo_text_color: block.settings.overlay_text_color_promo_1,
                            promo_link: block.settings.mega_image_link_1
                          %}
                        {% endif %}
                          
                        {% if block.settings.mega_image_2 and block.settings.show_promo_2_in_mobile_drawer %}
                          {% render 'mega-menu-promo-card', 
                            promo_wrapper_classes: "mobile-nav__item",
                            promo_block_id: block.id,
                            promo_img: block.settings.mega_image_2,
                            promo_img_crop: block.settings.image_2_aspect_ratio,
                            promo_text_overlay: block.settings.overlay_text_on_image_promo_2,
                            promo_text_heading: block.settings.mega_image_header_2,
                            promo_text_subheading: block.settings.mega_image_subheader_2,
                            promo_text_color: block.settings.overlay_text_color_promo_2,
                            promo_link: block.settings.mega_image_link_2
                          %}
                        {% endif %}
                      {% endif %}
                    {% endfor %}
                  </ul>
                {% endif %}
              </ul>
            </li>
          {% else %}
            <li class="mobile-nav__item top-level{% if link.active %} mobile-nav__item--active{% endif %}{% if is-mega-menu %} mega-menu--mobile no-links{% endif %}">
              {% if is-mega-menu %}
                <div class="mobile-nav__has-sublist">
                  <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
                  <div class="mobile-nav__toggle">
                    <button type="button" class="icon-fallback-text mobile-nav__toggle-open standalone-icon--wrapper touch-target icon-no-padding" aria-label="{{ 'cart.general.see_more' | t }}">
                      {% render 'theme-icon', icon: 'chevron_down', iconSize: 16, iconAttributes: 'aria-hidden="true"' %}
                    </button>
                    <button type="button" class="icon-fallback-text mobile-nav__toggle-close standalone-icon--wrapper touch-target icon-no-padding" aria-label="{{ 'layout.drawers.close_menu' | t }}">
                      {% render 'theme-icon', icon: 'chevron_up', iconSize: 16, iconAttributes: 'aria-hidden="true"' %}
                    </button>
                  </div>
                </div>

                <ul class="mobile-nav__sublist">
                  <ul class="mobile-promo--block">
                    {% for block in section.blocks %}

                      {% liquid
                        assign link-title = link.title | strip | downcase
                        assign block-title = block.settings.mega-menu | strip | downcase

                        assign image_1_stretch = false
                        assign crop_setting_1 = block.settings.image_1_aspect_ratio
                        if crop_setting_1 == "square"
                          assign image_1_crop = "aspect-ratio--square"
                          assign image_1_stretch = true
                        elsif crop_setting_1 == "tall"
                          assign image_1_crop = "aspect-ratio--tall"
                          assign image_1_stretch = true
                        elsif crop_setting_1 == "wide"
                          assign image_1_crop = "aspect-ratio--wide"
                          assign image_1_stretch = true
                        else
                          assign image_1_crop = false
                          assign image_1_stretch = false
                        endif

                        assign image_2_stretch = false
                        assign crop_setting_2 = block.settings.image_2_aspect_ratio
                        if crop_setting_2 == "square"
                          assign image_2_crop = "aspect-ratio--square"
                          assign image_2_stretch = true
                        elsif crop_setting_2 == "tall"
                          assign image_2_crop = "aspect-ratio--tall"
                          assign image_2_stretch = true
                        elsif crop_setting_2 == "wide"
                          assign image_2_crop = "aspect-ratio--wide"
                          assign image_2_stretch = true
                        else
                          assign image_2_crop = false
                          assign image_2_stretch = false
                        endif

                        assign first_promo_has_text = false
                        if block.settings.mega_image_header_1 != blank or block.settings.mega_image_subheader_1 != blank
                          assign first_promo_has_text = true
                        endif

                        assign second_promo_has_text = false
                        if block.settings.mega_image_header_2 != blank or block.settings.mega_image_subheader_2 != blank
                          assign second_promo_has_text = true
                        endif
                      %}

                      {% style %}
                        .block-id-{{ block.id }} .overlay-text-on-image-promo-1 {
                          color: rgba({{ block.settings.overlay_text_color_promo_1.rgba }});
                        }

                        .block-id-{{ block.id }} .overlay-text-on-image-promo-2 {
                          color: rgba({{ block.settings.overlay_text_color_promo_2.rgba }});
                        }
                      {% endstyle %}

                      {% if link-title == block-title %}
                        {% if block.settings.mega_image_1 == blank and block.settings.mega_image_2 == blank %}
                          <li class="mobile-nav__item {% if sub_link.active %} mobile-nav__item--active{% endif %}">
                            <p class="mega-menu--empty" {% unless request.design_mode %}style="visibility:hidden;"{% endunless %}>
                              {{ 'layout.header.mega_menu_empty' | t }}
                            </p>
                          </li>
                        {% else %}
                          {% if block.settings.mega_image_1 and block.settings.show_promo_1_in_mobile_drawer %}
                            <li class="mobile-nav__item block-id-{{ block.id }}">
                              <div class="inner mega-menu--image-wrapper">
                                <div class="mega-menu--image{% if block.settings.overlay_text_on_image_promo_1 %} overlay--enabled{% endif %}{% if first_promo_has_text %} has-promo-text{% endif %}">
                                  {% if block.settings.mega_image_link_1 %}
                                    <a class="mega-menu-promo--image{% if image_1_crop %} mega-menu-aspect-ratio {{ image_1_crop }}{% endif %}" href="{{ block.settings.mega_image_link_1 }}">
                                  {% else %}
                                    <div class="mega-menu-promo--image{% if image_1_crop %} mega-menu-aspect-ratio {{ image_1_crop }}{% endif %}">
                                  {% endif %}
                                  {% capture img_props %}style="max-width: {{ block.settings.mega_image_1.width }}px"{% endcapture %}
                        
                                  {% render 'responsive-image', image: block.settings.mega_image_1, allow_stretch: image_1_stretch, props: img_props %}
                                  {% if block.settings.mega_image_link_1 %}
                                    </a>
                                  {% else %}
                                    </div>
                                  {% endif %}
                        
                                  <div class="mega-menu--text">
                                    {% if block.settings.mega_image_header_1 %}
                                      <p class="h4 mega-menu--image-title{% if block.settings.mega_image_subheader_1 != blank %} has-padding{% endif %}{% if block.settings.overlay_text_on_image_promo_1 %} overlay-text-on-image-promo-1{% else %} default-menu-drawer-text-color{% endif %}">
                                        {% if block.settings.mega_image_link_1 %}
                                          <a href="{{ block.settings.mega_image_link_1 }}" class="{% if block.settings.overlay_text_on_image_promo_1 %} overlay-text-on-image-promo-1{% else %} default-menu-drawer-text-color{% endif %}">
                                        {% endif %}
                                        {{ block.settings.mega_image_header_1 }}
                                        {% if block.settings.mega_image_link_1 %}
                                          </a>
                                        {% endif %}
                                      </p>
                                    {% endif %}
                                    {% if block.settings.mega_image_subheader_1 %}
                                      <p class="h5 mega-menu--image-subtitle{% if block.settings.overlay_text_on_image_promo_1 %} overlay-text-on-image-promo-1{% else %} default-menu-drawer-text-color{% endif %}">
                                        {% if block.settings.mega_image_link_1 %}
                                          <a href="{{ block.settings.mega_image_link_1 }}" class="{% if block.settings.overlay_text_on_image_promo_1 %} overlay-text-on-image-promo-1{% else %} default-menu-drawer-text-color{% endif %}">
                                        {% endif %}
                                        {{ block.settings.mega_image_subheader_1 }}
                                        {% if block.settings.mega_image_link_1 %}
                                          </a>
                                        {% endif %}
                                      </p>
                                    {% endif %}
                                  </div>
                                </div>
                              </div>
                            </li>
                          {% endif %}
                          
                          {% if block.settings.mega_image_2 and block.settings.show_promo_2_in_mobile_drawer %}
                            <li class="mobile-nav__item block-id-{{ block.id }}">
                              <div class="inner mega-menu--image-wrapper">
                                <div class="mega-menu--image{% if block.settings.overlay_text_on_image_promo_2 %} overlay--enabled{% endif %}{% if second_promo_has_text %} has-promo-text{% endif %}">
                                  {% if block.settings.mega_image_link_2 %}
                                    <a class="mega-menu-promo--image{% if image_2_crop %} mega-menu-aspect-ratio {{ image_2_crop }}{% endif %}" href="{{ block.settings.mega_image_link_2 }}">
                                  {% else %}
                                    <div class="mega-menu-promo--image{% if image_2_crop %} mega-menu-aspect-ratio {{ image_2_crop }}{% endif %}">
                                  {% endif %}
                                  {% capture img_props %}style="max-width: {{ block.settings.mega_image_2.width }}px"{% endcapture %}
                        
                                  {% render 'responsive-image', image: block.settings.mega_image_2, allow_stretch: image_2_stretch, props: img_props %}
                                  {% if block.settings.mega_image_link_2 %}
                                    </a>
                                  {% else %}
                                    </div>
                                  {% endif %}
                        
                                  <div class="mega-menu--text">
                                    {% if block.settings.mega_image_header_2 %}
                                      <p class="h4 mega-menu--image-title{% if block.settings.mega_image_subheader_2 != blank %} has-padding{% endif %}{% if block.settings.overlay_text_on_image_promo_2 %} overlay-text-on-image-promo-2{% else %} default-menu-drawer-text-color{% endif %}">
                                        {% if block.settings.mega_image_link_2 %}
                                          <a href="{{ block.settings.mega_image_link_2 }}" class="{% if block.settings.overlay_text_on_image_promo_2 %} overlay-text-on-image-promo-2{% else %} default-menu-drawer-text-color{% endif %}">
                                        {% endif %}
                                        {{ block.settings.mega_image_header_2 }}
                                        {% if block.settings.mega_image_link_2 %}
                                          </a>
                                        {% endif %}
                                      </p>
                                    {% endif %}
                                    {% if block.settings.mega_image_subheader_2 %}
                                      <p class="h5 mega-menu--image-subtitle{% if block.settings.overlay_text_on_image_promo_2 %} overlay-text-on-image-promo-2{% else %} default-menu-drawer-text-color{% endif %}">
                                        {% if block.settings.mega_image_link_2 %}
                                          <a href="{{ block.settings.mega_image_link_2 }}" class="{% if block.settings.overlay_text_on_image_promo_2 %} overlay-text-on-image-promo-2{% else %} default-menu-drawer-text-color{% endif %}">
                                        {% endif %}
                                        {{ block.settings.mega_image_subheader_2 }}
                                        {% if block.settings.mega_image_link_2 %}
                                          </a>
                                        {% endif %}
                                      </p>
                                    {% endif %}
                                  </div>
                                </div>
                              </div>
                            </li>
                          {% endif %}
                        {% endif %}
                      {% endif %}
                    {% endfor %}
                  </ul>
                </ul>
              {% else %}
                <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
              {% endif %}
            </li>
          {% endif %}
        {% endfor %}
      </ul>

      <div class="mobile-nav--footer">
        <div class="mobile-nav locale--mobile">
          {{ locale }}
        </div>

        {% comment %}
          If customer accounts are enabled, provide login and create account links
        {% endcomment %}
        {% liquid 
          assign social_icons = false
          if settings.sm_facebook_link != blank or settings.sm_x_link != blank or settings.sm_youtube_link != blank or settings.sm_flickr_link != blank or settings.sm_pinterest_link != blank or settings.sm_instagram_link != blank or settings.sm_tumblr_link != blank or settings.sm_pinterest_link != blank or settings.sm_youtube_link != blank or settings.sm_vimeo_link != blank or settings.sm_flickr_link != blank or settings.sm_snapchat_link != blank or settings.sm_houzz_link != blank or settings.sm_linkedin_link != blank or settings.sm_tiktok_link != blank
            assign social_icons = true
          endif
        %}
        {% style %}
          .mobile-nav.nav--meta {
            display: grid;
            gap: 15px;
          }

          .mobile-nav.nav--meta .mobile-nav__item.customer-account-component,
          .mobile-nav.nav--meta .mobile-nav__item.sm-icons--wrapper {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
          }

          .mobile-nav.nav--meta .mobile-nav__item.sm-icons--wrapper #sm-icons {
            width: 100%;
          }

          {% comment %}
            Match the signed-out icon + "Account" label to the mobile drawer's other
            menu items: the slotted content isn't an <a> and the .nav--meta list isn't
            covered by the drawer's body-font rule, so set both explicitly. Colour uses
            the mobile-nav text colour (the desktop colour rule in _navigation.scss is
            scoped to .top-links--icon-links); the SVG icon uses currentColor so it
            follows along. Font uses the theme body stack to match the drawer links.
          {% endcomment %}
          .mobile-nav.nav--meta .customer-account-component .account-button__signed-out {
            display: inline-flex;
            align-items: center;
            line-height: normal;
            color: var(--menu-drawer-text-color);
            font-family: var(--body-font-stack);
          }

          .mobile-nav.nav--meta .customer-account-component shopify-account:hover .account-button__signed-out {
            color: var(--menu-drawer-text-hover-color);
          }

          {% comment %}
            Signed in there's no signed-out icon — Shopify's avatar sits flush with no
            built-in inset, so nudge the meta nav to keep it aligned (mobile drawer only).
          {% endcomment %}
          {% if customer %}
            @media screen and (max-width: 989px) {
              .mobile-nav.nav--meta {
                padding-left: 8px;
              }
            }
          {% endif %}

          {% comment %}
            The account web component is a single item that handles both signed-in
            and signed-out states, so the meta nav is now one account column plus an
            optional social-icons column (no more signed-in two-row layout).
          {% endcomment %}
          {% if shop.customer_accounts_enabled and social_icons %}
            .mobile-nav.nav--meta {
              grid-template-columns: 1fr 1fr;
              align-items: center;
            }

            .mobile-nav.nav--meta .mobile-nav__item.customer-account-component {
              grid-column-start: 1;
              grid-column-end: 2;
            }

            .mobile-nav.nav--meta .mobile-nav__item.sm-icons--wrapper {
              grid-column-start: 2;
              grid-column-end: 3;
            }

            .mobile-nav.nav--meta .mobile-nav__social-icons {
              justify-content: end;
            }
          {% elsif shop.customer_accounts_enabled and social_icons == false %}
            .mobile-nav.nav--meta {
              grid-template-columns: 1fr;
            }
          {% elsif shop.customer_accounts_enabled == false and social_icons %}
            .mobile-nav.nav--meta {
              grid-template-columns: 1fr;
              justify-content: center;
              width: fit-content;
              margin: 0 auto;
            }

            .mobile-nav.nav--meta .mobile-nav__social-icons {
              justify-content: center;
            }
          {% endif %}
        {% endstyle %}
        <ul class="mobile-nav nav--meta{% unless shop.customer_accounts_enabled or social_icons %} hidden{% endunless %}">
          {% if shop.customer_accounts_enabled %}
            <li class="mobile-nav__item customer-account-component">
              {% comment %}
                Shopify account web component (mobile drawer) — the same component as
                the desktop header. It handles both signed-in and signed-out states
                and replaces the previous Log in / Log out / Account text links.
                Signed out: the theme icon + clickable "Account" label live in the
                slot. Signed in: Shopify's avatar shows with no label (the component
                has no slot for that state).
              {% endcomment %}
              <shopify-account menu="{{ section.settings.customer_account_menu | default: 'customer-account-main-menu' }}" class="account-button">
                <span slot="signed-out-avatar" class="account-button__signed-out">
                  {% render 'theme-icon', icon: 'user-large', iconSize: 20 %}
                  <span class="header--supporting-text">{{ 'layout.header.account' | t }}</span>
                </span>
              </shopify-account>
            </li>
          {% endif %}

          {%- liquid
            assign enable_social_icons = false
            if section.settings.mobile_social_icons and social_icons
              assign enable_social_icons = true
            endif
          -%}
          {% if enable_social_icons %}
            <li class="mobile-nav__item sm-icons--wrapper">{% render 'social-icons', wrapper_classes: 'mobile-nav__social-icons', icon_wrapper_classes: 'icon-no-padding', icon_classes: 'fa-2x' %}</li>
          {% endif %}
        </ul>
      </div>
      <!-- //mobile-nav -->
    </div>
  </div>

  {% capture logo %}
    {% if section.settings.logo %}
      <a href="{{ routes.root_url }}" itemprop="url" class="site-header__logo-image">
        <style>
          .logo_image {
            max-height: unset!important;
            width: {{ section.settings.logo_max_width }}px;
          }
          @media screen and (max-width: 989px) {
            .logo_image {
              width: {{ section.settings.logo_max_width_mobile }}px;
            }
          }
        </style>
        {% assign alt = section.settings.logo.alt | default: shop.name | escape %}
        {% render 'responsive-image', image: section.settings.logo, alt: alt, props: 'itemprop="logo"', allow_stretch: true, blur: false, class: 'logo_image', loading: 'eager' %}
      </a>
    {% else %}
      <a class="site-header__logo-link" href="{{ routes.root_url }}" itemprop="url">{{ shop.name }}</a>
    {% endif %}
  {% endcapture %}

  {% capture overlay_logo %}
    {% if overlay %}
      {% if collection-overlay or homepage-overlay or list-collection-overlay or contact-overlay or article-overlay %}
        {% if section.settings.overlay_logo %}
          {% assign img = section.settings.overlay_logo %}
        {% elsif section.settings.logo %}
          {% assign img = section.settings.logo %}
        {% else %}
          {% assign img = none %}
        {% endif %}

        {% if img %}
          <a href="{{ routes.root_url }}" itemprop="url" class="site-header__logo-overlay-image">
            <style>
              .logo_overlay, 
              .logo_hover {
                max-height: unset!important;
                width: {{ section.settings.logo_max_width }}px;
              }
              @media screen and (max-width: 989px) {
                .logo_overlay,
                .logo_hover {
                  width: {{ section.settings.logo_max_width_mobile }}px;
                }
              }
            </style>

            <span class="opacity-logo">
              {% assign opacity_alt = img.alt | default: shop.name | escape %}
              {% render 'responsive-image', image: img, alt: opacity_alt, props: 'itemprop="logo"', blur: false, class: 'logo_overlay' %}
            </span>
            {% if section.settings.overlay_logo and section.settings.logo %}
              <span class="hover-logo">
                {% assign hover_alt = section.settings.logo.alt | default: shop.name | escape %}
                {% render 'responsive-image', image: section.settings.logo, alt: hover_alt, props: 'itemprop="logo"', blur: false, class: 'logo_hover' %}
              </span>
            {% endif %}
          </a>
        {% else %}
          <a class="site-header__logo-overlay-link" href="{{ routes.root_url }}" itemprop="url">{{ shop.name }}</a>
        {% endif %}
      {% endif %}
    {% endif %}
  {% endcapture %}

  {% capture header_logos %}
    <div class="site-header__logowrapper">

      {% if template == 'index' %}
        <h1 class="site-header__logo site-title" itemscope itemtype="http://schema.org/Organization">
      {% else %}
        <div class="header-font site-header__logo site-title" itemscope itemtype="http://schema.org/Organization">
      {% endif %}

        {{ logo }}
        {{ overlay_logo }}

      {% if template == 'index' %}
        </h1>
      {% else %}
        </div>
      {% endif %}

    </div>
  {% endcapture %}

  <header class="site-header wrapper-spacing--h{% if section.settings.sticky_header %} header-is-sticky{% endif %}{% if section.settings.logo-placement == 'above' %} logo_above{% endif %}{% if collection-overlay or homepage-overlay or list-collection-overlay or contact-overlay or article-overlay %} overlay-header{% endif %}{% if section.settings.dropdown_alignment == 'center' %} dropdown-alignment--center{% endif %}{% if section.settings.overlay_logo %} overlay-logo{% endif %}">
    <div class="site-header__wrapper site-header__wrapper--logo-{{ section.settings.logo-placement }} site-header__wrapper--{% if top_links != blank %}with{% else %}without{% endif %}-menu">
      <div class="site-header__wrapper__left">
        {% if section.settings.logo-placement == 'left' %}
          {{ header_logos }}
        {% elsif section.settings.logo-placement == 'center' and site_nav != blank %}
          {{ site_nav }}
        {% else %}
          {{ locale }}
        {% endif %}
      </div>

      <div class="site-header__wrapper__center">
        {% if section.settings.logo-placement != 'left' %}
          {{ header_logos }}
        {% endif %}
      </div>

      <div class="site-header__wrapper__right top-links">
        {% if section.settings.logo-placement == 'left' %}
          {{ site_nav }}
          {{ locale }}
        {% elsif section.settings.logo-placement == 'center' and site_nav != blank %}
          {{ locale }}
        {% endif %}

        {{ top_links }}
      </div>
    </div>

    {% if section.settings.logo-placement == 'above' and site_nav != blank %}
      <div class="site-header__nav-standalone">
        {{ site_nav }}
      </div>
    {% endif %}
  </header>

  {% if section.settings.enable_search %}
    {% render 'search-dropdown' %}
  {% endif %}

  <nav class="nav-bar mobile-nav-bar-wrapper{% if collection-overlay or homepage-overlay or list-collection-overlay or contact-overlay or article-overlay %} overlay-header{% endif %}{% if section.settings.overlay_logo %} overlay-logo{% endif %}">
    <div class="wrapper-spacing--h">
      <div class="mobile-nav-bar--inner">
        <div class="mobile-grid--table">

          <div class="grid__item three-twelfths">
            <div class="site-nav--mobile{% if section.settings.show_offers_drawer %} has-offers-icon{% endif %}">
              <button type="button" aria-label="{{ 'layout.navigation.menu' | t }}" class="hamburger-nav-button icon-fallback-text site-nav__link js-drawer-open-left-link standalone-icon--wrapper" aria-controls="NavDrawer" aria-expanded="false">
                {% render 'theme-icon', icon: 'hamburger_nav', widthUnset: true %}
                <span class="fallback-text">{{ 'layout.navigation.menu' | t }}</span>
              </button>

              {% if section.settings.show_offers_drawer and section.settings.enable_search %}
                {{ offers_icon_link }}
              {% endif %}
            </div>
          </div>

          <div class="grid__item six-twelfths">
            {{ header_logos }}
          </div>

          <div class="grid__item three-twelfths right-side{% unless section.settings.enable_search or section.settings.show_offers_drawer %} text-right{% else %} has-second-icon{% endunless %}">
            <div class="site-nav--mobile">

              {% if section.settings.enable_search %}
                <a href="{{ routes.search_url }}" class="search-button standalone-icon--wrapper" aria-label="{{ 'layout.header.search' | t }}" aria-controls="SearchDrawer" aria-expanded="false">
                  <span class="icon-fallback-text">
                    {% render 'theme-icon', icon: 'search-large', iconSize: 20 %}
                    <span class="fallback-text">{{ 'layout.header.search' | t }}</span>
                  </span>
                </a>
              {% elsif section.settings.show_offers_drawer %}
                {{ offers_icon_link }}
              {% endif %}

              <a href="{{ routes.cart_url }}" aria-label="{{ 'layout.cart.title' | t }}" class="{% if settings.cart_type == 'drawer' %}js-drawer-open-right-link {% endif %}site-nav__link{% if section.settings.cart_count %} cart-count-enabled {{ section.settings.cart-style }}{% endif %}{% if cart.item_count > 0 %} cart-count-visible{% endif %} standalone-icon--wrapper{% if section.settings.show_icons %} header-icons-enabled{% endif %}" aria-controls="CartDrawer" aria-expanded="false">
                <span class="icon-fallback-text">
                  {% if section.settings.cart-style == 'shopping-bag' %}
                    {% render 'theme-icon', icon: 'shopping-bag-large' %}
                  {% else %}
                    {% render 'theme-icon', icon: 'shopping-cart-large' %}
                  {% endif %}
                  {% if section.settings.cart_count %}
                    <span class="cart-item-count-bubble cart-item-count-header cart-item-count-header--quantity{% if cart.item_count == 0 %} hide{% endif %}">{{ cart.item_count }}</span>
                  {% endif %}
                  <span class="fallback-text">{{ 'layout.cart.title' | t }}</span>
                </span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>
</div>

<style>

  :root {
    --logo-max-width: {{ section.settings.logo_max_width | default: '450' | remove: 'px' }}px;
    --header-overlay-background-color: {{ overlay_bg_color }};

    {% if section.settings.sticky_header %}
      --sticky-header-offset: -1px;
      {%- comment -%}`--sticky-header-offset` compensates the `top: -1px;` on `.sticky-header` (which needs to be -1px so we can detect that header is sticky (using IntersectionObserver)){%- endcomment -%}
    {% endif %}
  }

  .site-title{
  	padding: {{ section.settings.logo_padding }}px 0;
  }

  @media screen and (max-width: 989px) {
    .site-title{
      padding: 15px 0;
    }
  }

  .site-header .site-header__wrapper .logo_image {
    max-width: {{ section.settings.logo_max_width }}px;
  }

  @media screen and (max-width: 989px) {
    .site-header .site-header__wrapper .logo_image {
      max-width: {{ section.settings.logo_max_width_mobile }}px;
    }
  }

  .site-nav__dropdown li, .inner .h4, .inner .h5 {
    text-align: {{ section.settings.dropdown_alignment }};
  }

  .template-index .header-section.sticky-header:not(.sticked) .overlay-header,
  .template-index .header-section:not(.sticky-header) .overlay-header,
  {% if collection-overlay %}
  .template-collection .header-section.sticky-header:not(.sticked) .overlay-header,
  .template-collection .header-section:not(.sticky-header) .overlay-header,
  {% endif %}
  .template-list-collections .header-section.sticky-header:not(.sticked) .overlay-header,
  .template-list-collections .header-section:not(.sticky-header) .overlay-header,
  .template-article .header-section.sticky-header:not(.sticked) .overlay-header,
  .template-article .header-section:not(.sticky-header) .overlay-header,
  .contact-page .header-section.sticky-header:not(.sticked) .overlay-header,
  .contact-page .header-section:not(.sticky-header) .overlay-header
  {
    background-color: {{ opaque_color }};
  }

  .overlay-header .grid--full {
    padding-left: 30px;
    padding-right: 30px;
  }

  @media only screen and (min-width: 768px) and (max-width: 1200px) {
    .overlay-header .grid--full {
      padding-left: 15px;
      padding-right: 15px;
    }
  }

  .template-index .overlay-header.force-hover,
  {% if collection-overlay %}.template-collection .overlay-header.force-hover, {% endif %}
  .template-list-collections .overlay-header.force-hover,
  .template-article .overlay-header.force-hover,
  .contact-page .overlay-header.force-hover
   {
    background-color: rgba({{ settings.header-bg-color.rgba }});
  }

  {% if section.settings.overlay_logo != blank and section.settings.logo == blank %}
    @media only screen and (min-width: 768px) {
      .template-index .overlay-header.ui.sticky:not(.top) .site-header__logo-link {
          display: none;
      }
      .template-index .header-section.sticky-header:not(.sticked) .overlay-header.force-hover .site-header__logo-link,
      .template-index .header-section.sticky-header:not(.sticked) .overlay-header:hover .site-header__logo-link,
      .template-collection .header-section.sticky-header:not(.sticked) .overlay-header.force-hover .site-header__logo-link,
      .template-collection .header-section.sticky-header:not(.sticked) .overlay-header:hover .site-header__logo-link,
      .template-list-collections .header-section.sticky-header:not(.sticked) .overlay-header.force-hover .site-header__logo-link,
      .template-list-collections .header-section.sticky-header:not(.sticked) .overlay-header:hover .site-header__logo-link,
      .template-article .header-section.sticky-header:not(.sticked) .overlay-header.force-hover .site-header__logo-link,
      .template-article .header-section.sticky-header:not(.sticked) .overlay-header:hover .site-header__logo-link,
      .contact-page .header-section.sticky-header:not(.sticked) .overlay-header.force-hover .site-header__logo-link,
      .contact-page .ui.sticky:not(.top) .overlay-header:hover .site-header__logo-link
      {
        display: block;
      }
    }
  {% endif %}
</style>

