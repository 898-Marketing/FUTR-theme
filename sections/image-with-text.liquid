{{ 'image-with-text-section.min.css' | asset_url | stylesheet_tag }}

{% case section.settings.colors %}
  {% when 'white' %}
    {%- assign color_scheme = 'color-scheme--white' -%}
  {% when 'light' %}
    {%- assign color_scheme = 'color-scheme--light' -%}
  {% when 'accent' %}
    {%- assign color_scheme = 'color-scheme--accent' -%}
  {% when 'dark' %}
    {%- assign color_scheme = 'color-scheme--dark' -%}
{% endcase %}

{% assign animation_offset = 2 %}
{% assign animation_order = 1 %}

<div
  class="wrapper-spacing--v{% if section.settings.section-width == 'content' %} wrapper-spacing--h{% endif %} {{ color_scheme }} image-with-text__container{% unless section.settings.text_overlapping_image %} feature-row--no-overlapping{% else %} feature-row--overlapping{% endunless %}"
  data-wetheme-section-type="image--image-with-text" 
  data-wetheme-section-id="{{ section.id }}"
  style="--padding-section-top: {{ section.settings.section_padding_top }}px; --padding-section-bottom: {{ section.settings.section_padding_bottom }}px;"
>

  {% capture image_layout %}
    <div class="grid__item homepage-content--image homepage-content--{{ section.id }}{% if section.settings.text_overlapping_image %} overlapping-text{% else %} large--one-half{% endif %}{% if settings.animations_enabled %} kb-enabled{% endif %}{% if section.settings.section-width == 'content' %} block-radius{% endif %}">
      <div>
        {% if section.settings.image != blank %}
          <div id="image-with-text--{{ section.id }}" class="img">
            {% render 'responsive-image', image: section.settings.image, sizes: '100vw', allow_stretch: true %}
          </div>
        {% else %}
          <div id="image-with-text--{{ section.id }}" class="placeholder-background img">
            {% if section.settings.text_overlapping_image %}
              {{ 'collection-4' | placeholder_svg_tag: 'icon icon--placeholder icon--placeholder--subdued-desktop' }}
            {% else %}
              {{ 'collection-4' | placeholder_svg_tag: 'icon icon--placeholder' }}
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  {% endcapture %}

  {% if section.settings.section-width == 'content' %}
    <div class="width--content">
  {% endif %}

    <div class="homepage-indiv-section-wrapper homepage-featured-content-wrapper feature-row__text--{{ section.settings.layout }} feature-row__text-alignment--{{ section.settings.text_alignment }} feature-row__text-alignment-mobile--{{ section.settings.text_alignment_mobile }}">
      {{ image_layout }}

      <div class="feature_row__image_wrapper{% if section.settings.text_overlapping_image %} homepage-featured-content-box{% else %} large--one-half{% endif %}">
        {% if section.blocks.size > 0 %}

          {% unless section.settings.text_overlapping_image %}
            <div class="no-overlap-content-box">
          {% endunless %}

            <div class="homepage-featured-content-box-inner{% if request.visual_preview_mode %} section-preview{% else %} show-on-scroll{% endif %}">

              {% for block in section.blocks %}
                {% case block.type %}
                  {% when 'heading' %}
                    {% if block.settings.title != blank %}
                      <div class="sitewide--title-wrapper" style="margin-bottom: {{ block.settings.heading_bottom_spacing }}px;" data-animate data-animate-order="{{ animation_order | plus: animation_offset }}" {{ block.shopify_attributes }}>
                        <h2 class="homepage-sections--title" style="margin-bottom: 0;">{{ block.settings.title | escape }}</h2>
                      </div>
                      {% assign animation_order = animation_order | plus: 1 %}
                    {% endif %}

                  {% when 'text' %}
                    {% if block.settings.text != blank %}
                      <div class="rte featured-row__subtext textarea text-link-animated richtext-block" style="margin-bottom: {{ block.settings.text_bottom_spacing }}px;" data-animate data-animate-order="{{ animation_order | plus: animation_offset }}" {{ block.shopify_attributes }}>
                        {{ block.settings.text }}
                      </div>
                      {% assign animation_order = animation_order | plus: 1 %}
                    {% endif %}

                  {% when 'text_with_icon' %}
                    {% liquid
                      assign icon = block.settings.icon
                      assign custom_icon = false
                      if block.settings.custom_icon
                        assign icon = block.settings.custom_icon
                        assign custom_icon = true
                      endif
                    %}

                    {% capture block_attr %}
                      style="margin-bottom: {{ block.settings.text_with_icon_bottom_spacing }}px;"
                      data-animate
                      data-animate-order="{{ animation_order | plus: animation_offset }}"
                    {% endcapture %}

                    {%- if icon != 'none' or  block.settings.text != blank -%}
                      {% render 'text-with-icon', icon: icon,
                        block_attributes: block.shopify_attributes,
                        attributes: block_attr,
                        custom_icon: custom_icon,
                        text: block.settings.text,
                        link: block.settings.link,
                        classes: 'image-with-text__icon-block'
                      %}
                      {% assign animation_order = animation_order | plus: 1 %}
                    {%- endif -%}

                  {% when 'button' %}
                    {% if block.settings.button_label != blank %}
                      {% if block.settings.override_button_colors %}
                        {% render 'button-color-overrides',
                          id: block.id,
                          style: block.settings.buttons_style,
                          text_color: block.settings.button_text_color,
                          background_color: block.settings.button_background_color
                        %}
                      {% endif %}

                      {% capture button_attr %}
                        data-animate
                        data-animate-order="{{ animation_order | plus: animation_offset }}"
                        style="margin-bottom: {{ block.settings.button_bottom_spacing }}px;"
                      {% endcapture %}
                      
                      {% render 'dynamic-section-button',
                        id: block.id,
                        link: block.settings.button_link,
                        label: block.settings.button_label,
                        style: block.settings.buttons_style,
                        div_classes: 'clearfix',
                        a_classes: 'homepage-featured-box-btn',
                        attributes: button_attr,
                        block_attributes: block.shopify_attributes
                      %}
                      {% assign animation_order = animation_order | plus: 1 %}
                    {% endif %}
                {% endcase %}
              {% endfor %}

            </div>

          {% unless section.settings.text_overlapping_image %}
            </div>
          {% endunless %}
        {% endif %}
      </div>
    </div>

  {% if section.settings.section-width == 'content' %}
    </div>
  {% endif %}

</div>

