<!--
  Zing Ingredients section — Concept 1B: filterable, expandable card grid.
  Ported from the client-approved design handoff (zing-ingredients-1B.html).
  Ingredient content lives in blocks so it can be edited per product.
-->

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

{%- style -%}
  #shopify-section-{{ section.id }} .zing-ingredients {
    --zing-ink: {{ section.settings.color_ink }};
    --zing-paper: {{ section.settings.color_paper }};
    --zing-muted: {{ section.settings.color_muted }};
    --zing-faint: {{ section.settings.color_faint }};
    --cat-body: {{ section.settings.color_body }};
    --cat-body-pill: {{ section.settings.color_body_pill }};
    --cat-mind: {{ section.settings.color_mind }};
    --cat-mind-pill: {{ section.settings.color_mind_pill }};
    --cat-energy: {{ section.settings.color_energy }};
    --cat-energy-pill: {{ section.settings.color_energy_pill }};
  }

  .zing-ingredients * { box-sizing: border-box; }
  .zing-ingredients {
    font-family: 'Archivo', system-ui, sans-serif;
    color: var(--zing-ink);
    background: var(--zing-paper);
    padding: 56px 60px;
    -webkit-font-smoothing: antialiased;
  }
  @media (max-width: 640px) { .zing-ingredients { padding: 40px 20px; } }

  .zing-header {
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 20px; margin-bottom: 32px;
  }
  .zing-kicker {
    font-size: 13px; font-weight: 800; letter-spacing: .16em;
    text-transform: uppercase; color: var(--cat-mind); margin-bottom: 8px;
  }
  .zing-title { font-size: 40px; font-weight: 900; letter-spacing: -.02em; margin: 0; }
  @media (max-width: 640px) { .zing-title { font-size: 30px; } }

  /* Filter tabs */
  .zing-tabs { display: flex; gap: 10px; flex-wrap: wrap; }
  .zing-tab {
    padding: 9px 18px; border-radius: 999px; cursor: pointer;
    font-family: inherit; font-weight: 800; font-size: 13px; letter-spacing: .03em;
    border: 1px solid rgba(14,17,22,.15); background: transparent; color: var(--zing-ink);
    transition: all .15s ease;
  }
  .zing-tab:hover { border-color: rgba(14,17,22,.4); }
  .zing-tab[aria-selected="true"] {
    background: var(--zing-ink); color: var(--zing-paper); border-color: var(--zing-ink);
  }

  /* Card grid */
  .zing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  @media (max-width: 900px) { .zing-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .zing-grid { grid-template-columns: 1fr; } }

  .ing-card {
    display: flex; flex-direction: column; cursor: pointer; text-align: left;
    background: #fff; border-radius: 18px; padding: 22px 22px 18px;
    border: 1px solid rgba(14,17,22,.07);
    border-top: 5px solid var(--cat);
    font-family: inherit;
    box-shadow: 0 12px 28px -22px rgba(14,17,22,.4);
    transition: box-shadow .22s ease, transform .22s ease;
  }
  .ing-card:hover { transform: translateY(-2px); }
  .ing-card[aria-expanded="true"] {
    box-shadow: 0 30px 56px -30px rgba(14,17,22,.6);
    transform: translateY(-4px);
  }
  .ing-card.is-hidden { display: none; }

  .ing-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
  .ing-pill {
    display: inline-block; font-size: 11px; font-weight: 800; letter-spacing: .06em;
    text-transform: uppercase; padding: 4px 10px; border-radius: 999px;
    background: var(--cat-pill); color: var(--zing-ink);
  }
  .ing-name { font-size: 20px; font-weight: 900; letter-spacing: -.01em; margin: 12px 0 0; color: #000; }
  .ing-sub { font-size: 12px; font-weight: 700; color: var(--zing-faint); margin-top: 2px; }
  .ing-dose { text-align: right; line-height: 1; }
  .ing-dose b { font-size: 32px; font-weight: 900; letter-spacing: -.03em; color: #000; }
  .ing-dose span { font-size: 13px; font-weight: 800; color: var(--zing-faint); }

  .ing-is { font-size: 13.5px; line-height: 1.5; color: #3A3F46; margin: 14px 0 0; }
  .ing-is p { margin: 0; }

  .ing-why {
    overflow: hidden; max-height: 0; opacity: 0; margin-top: 0;
    transition: max-height .3s ease, opacity .25s ease, margin-top .3s ease;
  }
  .ing-card[aria-expanded="true"] .ing-why { max-height: 220px; opacity: 1; margin-top: 14px; }
  .ing-why-inner { border-top: 1px dashed rgba(14,17,22,.15); padding-top: 12px; }
  .ing-why-label {
    font-size: 11px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase;
    color: var(--cat); margin-bottom: 3px;
  }
  .ing-why-inner p { font-size: 13.5px; line-height: 1.5; color: #3A3F46; margin: 0; }

  .ing-toggle {
    display: flex; align-items: center; gap: 6px; margin-top: 14px;
    font-size: 12px; font-weight: 800; letter-spacing: .04em; text-transform: uppercase;
    color: var(--cat);
  }

  /* Category color assignment */
  .zing-ingredients [data-cat="body"]   { --cat: var(--cat-body);   --cat-pill: var(--cat-body-pill); }
  .zing-ingredients [data-cat="mind"]   { --cat: var(--cat-mind);   --cat-pill: var(--cat-mind-pill); }
  .zing-ingredients [data-cat="energy"] { --cat: var(--cat-energy); --cat-pill: var(--cat-energy-pill); }
{%- endstyle -%}

<section class="zing-ingredients" aria-labelledby="zing-title-{{ section.id }}">
  <header class="zing-header">
    <div>
      {%- if section.settings.kicker != blank -%}
        <div class="zing-kicker">{{ section.settings.kicker }}</div>
      {%- endif -%}
      <h2 class="zing-title" id="zing-title-{{ section.id }}">{{ section.settings.heading }}</h2>
    </div>
    <div class="zing-tabs" role="tablist" aria-label="Filter ingredients by benefit">
      <button class="zing-tab" role="tab" aria-selected="true"  data-filter="all">All</button>
      <button class="zing-tab" role="tab" aria-selected="false" data-filter="body">Body</button>
      <button class="zing-tab" role="tab" aria-selected="false" data-filter="mind">Mind</button>
      <button class="zing-tab" role="tab" aria-selected="false" data-filter="energy">Energy</button>
    </div>
  </header>

  <div class="zing-grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'ingredient' -%}
        <button class="ing-card" data-cat="{{ block.settings.category }}" aria-expanded="false" {{ block.shopify_attributes }}>
          <div class="ing-top">
            <div>
              <span class="ing-pill">{{ block.settings.category_label }}</span>
              <h3 class="ing-name">{{ block.settings.name }}</h3>
              {%- if block.settings.sub != blank -%}
                <div class="ing-sub">{{ block.settings.sub }}</div>
              {%- endif -%}
            </div>
            <div class="ing-dose"><b>{{ block.settings.dose }}</b><span>{{ block.settings.unit }}</span></div>
          </div>
          {%- if block.settings.description != blank -%}
            <div class="ing-is">{{ block.settings.description }}</div>
          {%- endif -%}
          <div class="ing-why"><div class="ing-why-inner">
            <div class="ing-why-label">Why it helps</div>
            <div>{{ block.settings.why_it_helps }}</div>
          </div></div>
          <div class="ing-toggle">Why it helps +</div>
        </button>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<script>
  (function () {
    document.querySelectorAll('#shopify-section-{{ section.id }} .zing-ingredients').forEach(function (root) {
      var tabs = root.querySelectorAll('.zing-tab');
      var cards = root.querySelectorAll('.ing-card');

      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          tabs.forEach(function (t) { t.setAttribute('aria-selected', t === tab); });
          var filter = tab.dataset.filter;
          cards.forEach(function (card) {
            var show = filter === 'all' || card.dataset.cat === filter;
            card.classList.toggle('is-hidden', !show);
            card.setAttribute('aria-expanded', 'false');
            setToggleLabel(card);
          });
        });
      });

      cards.forEach(function (card) {
        card.addEventListener('click', function () {
          var open = card.getAttribute('aria-expanded') === 'true';
          card.setAttribute('aria-expanded', String(!open));
          setToggleLabel(card);
        });
      });

      function setToggleLabel(card) {
        var open = card.getAttribute('aria-expanded') === 'true';
        card.querySelector('.ing-toggle').textContent = open ? 'Close –' : 'Why it helps +';
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Ingredients Grid",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "What's inside"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for body & mind"
    },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "color_ink", "label": "Ink (text)", "default": "#0E1116" },
    { "type": "color", "id": "color_paper", "label": "Paper (background)", "default": "#F5F4EE" },
    { "type": "color", "id": "color_muted", "label": "Muted text", "default": "#5A5F66" },
    { "type": "color", "id": "color_faint", "label": "Faint text", "default": "#8A9099" },
    { "type": "header", "content": "Category colors — Body" },
    { "type": "color", "id": "color_body", "label": "Body accent", "default": "#8FBF2E" },
    { "type": "color", "id": "color_body_pill", "label": "Body pill background", "default": "#DCF29A" },
    { "type": "header", "content": "Category colors — Mind" },
    { "type": "color", "id": "color_mind", "label": "Mind accent", "default": "#3E82E6" },
    { "type": "color", "id": "color_mind_pill", "label": "Mind pill background", "default": "#BAD4FF" },
    { "type": "header", "content": "Category colors — Energy" },
    { "type": "color", "id": "color_energy", "label": "Energy accent", "default": "#F0642A" },
    { "type": "color", "id": "color_energy_pill", "label": "Energy pill background", "default": "#FFCDA9" }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "select",
          "id": "category",
          "label": "Category",
          "options": [
            { "value": "body", "label": "Body" },
            { "value": "mind", "label": "Mind" },
            { "value": "energy", "label": "Energy" }
          ],
          "default": "body"
        },
        { "type": "text", "id": "category_label", "label": "Category label (shown on pill)", "default": "Body" },
        { "type": "text", "id": "name", "label": "Ingredient name", "default": "Ingredient name" },
        { "type": "text", "id": "sub", "label": "Subtitle (optional, e.g. brand name)" },
        { "type": "text", "id": "dose", "label": "Dose amount", "default": "0" },
        { "type": "text", "id": "unit", "label": "Dose unit", "default": "mg" },
        { "type": "richtext", "id": "description", "label": "What it is" },
        { "type": "richtext", "id": "why_it_helps", "label": "Why it helps" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredients Grid",
      "blocks": [
        { "type": "ingredient", "settings": { "category": "body", "category_label": "Body", "name": "L-Citrulline", "dose": "2000", "unit": "mg", "description": "<p>An amino acid naturally found in foods like watermelon.</p>", "why_it_helps": "<p>Helps support healthy blood flow, stamina, and endurance during activity.</p>" } },
        { "type": "ingredient", "settings": { "category": "body", "category_label": "Body", "name": "Taurine", "dose": "1000", "unit": "mg", "description": "<p>An amino acid produced by the body and found in foods like fish, meat, and even breast milk.</p>", "why_it_helps": "<p>Supports hydration, electrolyte balance, and normal muscle function during activity.</p>" } },
        { "type": "ingredient", "settings": { "category": "mind", "category_label": "Mind", "name": "Citicoline", "sub": "Cognizin®", "dose": "250", "unit": "mg", "description": "<p>A clinically studied form of citicoline, a nutrient the body uses to build healthy brain cell membranes.</p>", "why_it_helps": "<p>Enhances focus, mental clarity, and reaction time — helping athletes stay sharp on and off the field.</p>" } },
        { "type": "ingredient", "settings": { "category": "mind", "category_label": "Mind", "name": "L-Tyrosine", "dose": "250", "unit": "mg", "description": "<p>An amino acid the body uses to help support focus and concentration.</p>", "why_it_helps": "<p>Supports concentration, reaction time, and composure under stress, keeping youth athletes mentally sharp.</p>" } },
        { "type": "ingredient", "settings": { "category": "energy", "category_label": "Energy", "name": "Vitamin B6", "sub": "as Pyridoxine HCl", "dose": "1", "unit": "mg", "description": "<p>A water-soluble B vitamin that helps convert food into energy and supports normal nervous system function.</p>", "why_it_helps": "<p>Helps support energy metabolism, focus, and normal muscle function.</p>" } },
        { "type": "ingredient", "settings": { "category": "energy", "category_label": "Energy", "name": "Vitamin B12", "sub": "as Methylcobalamin", "dose": "2", "unit": "mcg", "description": "<p>An essential B-vitamin needed for red blood cell formation and nervous system health.</p>", "why_it_helps": "<p>Supports oxygen transport in the blood and energy metabolism.</p>" } }
      ]
    }
  ]
}
{% endschema %}
