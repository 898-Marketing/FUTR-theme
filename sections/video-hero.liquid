{{ 'video-hero-section.min.css' | asset_url | stylesheet_tag }}

{% assign type = 'mp4' %}
{% unless section.settings.video %}
    {% assign type = section.settings.url.type %}
{% endunless %}

{% capture textalignment %}
    {% case section.settings.textAlignment %}
    {% when 'top-left' %}
        text-align-top-left
    {% when 'top-center' %}
        text-align-top-center
    {% when 'top-right' %}
        text-align-top-right
    {% when 'center-left' %}
        text-align-center-left
    {% when 'center' %}
        text-align-center
    {% when 'center-right' %}
        text-align-center-right
    {% when 'bottom-left' %}
        text-align-bottom-left
    {% when 'bottom-center' %}
        text-align-bottom-center
    {% when 'bottom-right' %}
        text-align-bottom-right
    {% endcase %}
{% endcapture %}

{% capture desktopheight %}
    {% case section.settings.desktopHeight %}
    {% when '450' %}
        desktop-height-450
    {% when '550' %}
        desktop-height-550
    {% when '650' %}
        desktop-height-650
    {% when '750' %}
        desktop-height-750
    {% when 'fullscreen' %}
        desktop-height-fullscreen
    {% endcase %}
{% endcapture %}

{% capture mobileheight %}
    {% case section.settings.mobileHeight %}
    {% when '250' %}
        mobile-height-250
    {% when '350' %}
        mobile-height-350
    {% when '450' %}
        mobile-height-450
    {% when '550' %}
        mobile-height-550
    {% when 'fullscreen' %}
        mobile-height-fullscreen
    {% when 'fit' %}
        mobile-height-fit
    {% endcase %}
{% endcapture %}

{% if request.visual_preview_mode %}
  {% assign desktopheight = 'desktop-height-650' %}
  {% assign mobileheight = 'mobile-height-350' %}
{% endif %}

{% capture isplaceholder %}
    {% if section.settings.url contains "watch?v=_9VUPq3SxOc" %}
        is-placeholder
    {% endif %}
{% endcapture %}

{% capture media_icon %}
    <svg viewBox="0 0 61 61">
        <rect x="0.5" y="0.5" width="60" height="60" fill="none" stroke="currentColor" stroke-opacity="0.05" stroke-miterlimit="10"/>
        <path d="M25,21.39a1,1,0,0,0-1.51.86V38.64a1,1,0,0,0,1.55.83l13.11-8.67a1,1,0,0,0,0-1.7Z" fill="currentColor"/>
    </svg>
{% endcapture %}

{% assign button_blocks = section.blocks | where: "type", "button" %}
{% assign buttonHidden = false %}
{% if section.settings.link != blank and button_blocks.size == 0 %}
    {% assign buttonHidden = true %}
{% endif %}

{% assign buttonEnabled = false %}
{% if button_blocks.size > 0 %}
    {% assign buttonEnabled = true %}
{% endif %}

{% assign animation_offset = 2 %}
{% assign animation_order = 1 %}

<section
    class="wrapper-spacing--v{% if section.settings.section_width == 'content' %} wrapper-spacing--h{% endif %}{% if request.visual_preview_mode %} section-preview{% else %} show-on-scroll{% endif %}"
    data-wetheme-section-type="video--video-hero"
    data-wetheme-section-id="{{ section.id }}"
    style="--margin-section-top: {{ section.settings.section_margin_top }}px; --margin-section-bottom: {{ section.settings.section_margin_bottom }}px;"
>
  <div{% if section.settings.section_width == 'content' %} class="width--content block-radius-clip"{% endif %}>
    <div class="video-hero-wrapper">
      <div class="homepage-content--{{ section.id }} hero-video {{ desktopheight | strip }} {{ mobileheight | strip }} {{ isplaceholder | strip }}{% if section.settings.link != blank and section.settings.button_label == blank %} is-link{% endif %}">
        <div class="hero-video--wrapper">
            <div class="hero-video--media type-{{ type }}">
              {% liquid 
                if section.settings.video != blank
                  assign video = section.settings.video
                elsif section.settings.url != blank
                  assign video = section.settings.url
                endif
        
                assign loop = true
                assign autoplay = true
                assign mute = true
                assign show_controls = false
              %}
                {% if video %}
                  <safe-load-scripts class="hidden">
                    <script src="{{ 'deferred-media-component.js' | asset_url }}" defer="defer" type="module" data-flow-load-key="deferred-media"></script>
                  </safe-load-scripts>
                  
                  {% render 'deferred-media', 
                    delayed_media: video, 
                    section_id: section.id, 
                    enable_video_loop: loop, 
                    enable_autoplay: autoplay, 
                    mute: mute, 
                    show_controls: show_controls,
                    is_product_media: false,
                    aspect_ratio: 'original',
                    media_type: 'grid',
                    video_alt_text: section.settings.video_alt_text,
                    is_background_media: true
                  %}
                {% else %}
                  {% assign placeholder_classes = 'icon icon--placeholder icon--placeholder--subdued' %}
                  {% if section.settings.section_width == 'content' %}
                    {% assign placeholder_classes = placeholder_classes | append: ' block-radius' %}
                  {% endif %}
                  {{ 'lifestyle-1' | placeholder_svg_tag: placeholder_classes | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"' }}
                {% endif %}
            </div>
              <div class="hero-video--text wrapper-spacing--h{% if request.visual_preview_mode %} hero-video--text--preview{% endif %}">
                <div class="hero-video--text-content {{ textalignment | strip }}">
                  {% if section.blocks.size > 0 %}
                    <div class="text-content--inner{% if section.settings.textShadow %} text-shadow{% endif %}">
                      {% for block in section.blocks %}
                        {% case block.type %}
                          {% when 'heading' %}
                            {% if block.settings.title != blank %}
                              <div class="hero-video--text-title" style="margin-bottom: {{ block.settings.heading_bottom_spacing }}px;" data-animate data-animate-order="{{ animation_order | plus: animation_offset }}" {{ block.shopify_attributes }}>
                                  <h2 class="homepage-sections--title text-size-{{ block.settings.heading--text-size }}px" id="{{ section.id }}_title" style="margin-bottom: 0;">
                                      {% if buttonHidden == true %}<a href="{{ section.settings.link }}">{% endif %}{{ block.settings.title | escape }}{% if buttonHidden == true %}</a>{% endif %}
                                  </h2>
                              </div>
                              {% assign animation_order = animation_order | plus: 1 %}
                            {% endif %}

                          {% when 'subheading' %}
                            {% if block.settings.subheading != blank %}
                              <div class="hero-video--text-subtitle" style="margin-bottom: {{ block.settings.subheading_bottom_spacing }}px;" data-animate data-animate-order="{{ animation_order | plus: animation_offset }}" {{ block.shopify_attributes }}>
                                  <p class="text-size-{{ block.settings.subheading--text-size }}px" style="margin-bottom: 0;">{{ block.settings.subheading }}</p>
                              </div>
                              {% assign animation_order = animation_order | plus: 1 %}
                            {% endif %}

                          {% when 'text_with_icon' %}
                            {% liquid
                              assign icon = block.settings.icon
                              assign custom_icon = false
                              if block.settings.custom_icon
                                assign icon = block.settings.custom_icon
                                assign custom_icon = true
                              endif
                            %}

                            {% capture block_attr %}
                              style="margin-bottom: {{ block.settings.text_with_icon_bottom_spacing }}px;"
                              data-animate
                              data-animate-order="{{ animation_order | plus: animation_offset }}"
                            {% endcapture %}

                            {%- if icon != 'none' or  block.settings.text != blank -%}
                              {% render 'text-with-icon', icon: icon,
                                block_attributes: block.shopify_attributes,
                                attributes: block_attr,
                                custom_icon: custom_icon,
                                text: block.settings.text,
                                link: block.settings.link,
                                classes: 'video-hero__icon-block'
                              %}
                              {% assign animation_order = animation_order | plus: 1 %}
                            {%- endif -%}

                          {% when 'page' %}
                            {% if block.settings.page.content %}
                              <div class="hero-video--text-page text-link-animated" style="margin-bottom: {{ block.settings.page_bottom_spacing }}px;" data-animate data-animate-order="{{ animation_order | plus: animation_offset }}" {{ block.shopify_attributes }}>{{ block.settings.page.content }}</div>
                              {% assign animation_order = animation_order | plus: 1 %}
                            {% endif %}

                          {% when 'image' %}
                            <div class="hero-video--image-block block-radius-clip" style="margin-bottom: {{ block.settings.image_bottom_spacing }}px;" data-animate data-animate-order="{{ animation_order | plus: animation_offset }}" {{ block.shopify_attributes }}>
                              {% if block.settings.image_link != blank %}
                                <a href="{{ block.settings.image_link }}" class="hero-video--image-link" data-animate-hover-zoom>
                              {% endif %}
                                {% if block.settings.image != blank %}
                                  {% render 'responsive-image', image: block.settings.image, loading: 'eager' %}
                                {% else %}
                                  {{ 'image' | placeholder_svg_tag: 'icon icon--placeholder block-radius' }}
                                {% endif %}
                              {% if block.settings.image_link != blank %}
                                </a>
                              {% endif %}
                            </div>
                            {% assign animation_order = animation_order | plus: 1 %}

                          {% when 'button' %}
                            {% if block.settings.button_label != blank %}
                              {% capture button_attr %}
                                data-section-main-link
                                data-animate
                                data-animate-order="{{ animation_order | plus: animation_offset }}"
                                style="margin-bottom: {{ block.settings.button_bottom_spacing }}px;"
                              {% endcapture %}
                              {% render 'dynamic-section-button',
                                id: block.id,
                                link: block.settings.button_link,
                                label: block.settings.button_label,
                                style: block.settings.buttons_style,
                                div_classes: 'homepage-section-btn-container',
                                a_classes: 'homepage-section-btn',
                                attributes: button_attr,
                                block_attributes: block.shopify_attributes
                              %}
                              {% if block.settings.override_button_colors %}
                                {% render 'button-color-overrides',
                                  id: block.id,
                                  style: block.settings.buttons_style,
                                  text_color: block.settings.button-text,
                                  background_color: block.settings.button-background
                                %}
                              {% endif %}
                              {% assign animation_order = animation_order | plus: 1 %}
                            {% endif %}
                        {% endcase %}
                      {% endfor %}
                    </div>
                  {% endif %}
                </div>
            </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
    {% if section.settings.textColor != 'rgba(0,0,0,0)' %}
      .homepage-content--{{ section.id }} .hero-video--text,
      .homepage-content--{{ section.id }} .hero-video--text .hero-video--text-title a:not(.btn) {
        color: rgba({{ section.settings.textColor.rgba }});
      }
    {% else %}
      .homepage-content--{{ section.id }} .hero-video--text,
      .homepage-content--{{ section.id }} .hero-video--text .hero-video--text-title a:not(.btn) {
        color: var(--text-color);
      }
    {% endif %}

		{% if section.settings.subheading == blank and buttonEnabled == false %}
			.homepage-content--{{ section.id }} .homepage-sections--title {
				margin-bottom: 0;
			}
		{% endif %}

		{% if buttonEnabled == false %}
			.homepage-content--{{ section.id }} .hero-video--text-content div.hero-video--text-subtitle {
				margin-bottom: 0;
			}
			.homepage-content--{{ section.id }} .hero-video--text-subtitle p {
				margin-bottom: 0;
			}
		{% endif %}

		{% if section.settings.title == blank and section.settings.subheading == blank %}
			.homepage-content--{{ section.id }} .hero-video--text-content .homepage-section-btn {
				margin-top: 0;
			}
		{% endif %}
</style>

