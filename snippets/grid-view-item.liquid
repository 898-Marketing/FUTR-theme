{% liquid 
  assign image_stretch = false

  assign crop_setting = settings.product-grid
  if crop_setting == "square"
    assign image_crop = "aspect-ratio--square"
    assign image_stretch = true
  elsif crop_setting == "tall"
    assign image_crop = "aspect-ratio--tall"
    assign image_stretch = true
  elsif crop_setting == "wide"
    assign image_crop = "aspect-ratio--wide"
    assign image_stretch = true
  else
    assign image_crop = false
    assign image_stretch = false
  endif

  assign alignment_class = 'text-align--' | append: settings.product_card_text_alignment

  assign quick_shop_desktop_enabled = settings.enable_quick_shop_desktop
  assign quick_shop_mobile_enabled = settings.enable_quick_shop_mobile
  assign card_color_swatches_enabled = settings.show_card_color_swatches
  assign vendor_enabled = settings.show_product_card_vendor
  assign price_enabled = settings.show_product_card_price

  if is_search_result
    assign quick_shop_desktop_enabled = false
    assign quick_shop_mobile_enabled = false
    assign card_color_swatches_enabled = false
    assign vendor_enabled = settings.predictive_search_show_vendor
    assign price_enabled = settings.predictive_search_show_price
  endif

  if quick_shop_desktop_enabled == false and quick_shop_mobile_enabled
    assign quick_shop_mobile_only = true
  endif

  if quick_shop_desktop_enabled and quick_shop_mobile_enabled == false
    assign quick_shop_desktop_only = true
  endif

  if vendor_enabled
    assign vendor_font = 'product-grid--vendor-font-' | append: settings.type_card_vendor_font
  endif

  assign title_font = 'product-grid--title-font-' | append: settings.type_card_title_font

  assign login_to_order = false
  if settings.login_to_order and customer == blank
    for tag in product.tags
      assign formatted_tag = tag | downcase | replace: ' ', ''
      if formatted_tag == 'b2b' or formatted_tag == 'wholesale'
        assign login_to_order = true
        break
      endif
    endfor
  endif

  if login_to_order
    assign price_enabled = false
  endif

  if price_enabled
    assign price_font = 'product-grid--price-font-' | append: settings.type_card_price_font
  endif

  if card_color_swatches_enabled
    assign show_color_label = settings.show_card_color_swatch_label
  endif

  if settings.product_card_max_lines > 0
    if settings.product_card_max_lines == 1
      assign truncate_value = 20
    elsif settings.product_card_max_lines == 2
      assign truncate_value = 40
    elsif settings.product_card_max_lines == 3
      assign truncate_value = 60
    elsif settings.product_card_max_lines == 4
      assign truncate_value = 80
    endif
  endif

  assign card_form_id = 'add-to-cart-' | append: section.id | append: '-' | append: product.id
%}

{% if enable_badges and badge_anim_order %}
  {% capture badge_attributes %}
    data-animate
    data-animate-left
    data-animate-order="{% render 'block-animation-offset', 
      title: section.settings.title, 
      description: section.settings.description,
      base: badge_anim_order
    %}"
    {% if badge_anim_order_ipad %}
      data-animate-order-ipad="{% render 'block-animation-offset', 
        title: section.settings.title, 
        description: section.settings.description,
        base: badge_anim_order_ipad
      %}"
    {% endif %}
    {% if badge_anim_order_mobile %}
      data-animate-order-mobile="{% render 'block-animation-offset', 
        title: section.settings.title, 
        description: section.settings.description,
        base: badge_anim_order_mobile
      %}"
    {% endif %}
  {% endcapture %}
{% endif %}

<safe-load-scripts class="hidden">
  <script src="{{ 'product-card-component.js' | asset_url }}" type="module" defer="defer" data-flow-load-key="component-product-card"></script>
</safe-load-scripts>

<product-card
  class="grid-view-item {{ alignment_class }}{% if settings.grid_spacing == '3' %} grid-view-item--tight{% endif %}"
  data-product-available="{{ product.available }}"
  data-product-variants-size="{{ product.variants.size }}"
  data-product-id="{{ product.variants.first.id }}"
  data-product-url="{{ product.url | within: collection }}"
  data-grid-count-desktop="{{ grid_count_desktop }}"
  data-grid-count-mobile="{{ grid_count_mobile }}"
  data-current_variant="{{ product.selected_or_first_available_variant | json | escape }}"
  {% if animate %}
    data-animate
    data-animate-order="{{ animate_order }}"
    data-animate-order-ipad="{{ animate_order_ipad }}"
    data-animate-order-mobile="{{ animate_order_mobile }}"
  {% endif %}
>
  <div>
    <div class="grid-view-item-image">

      {%- liquid
        assign preorder_string = 'products.product.preorder' | t | downcase
        assign preorder_product = false
        assign custom_badge = nil

        if product.available
          for tag in product.tags
            assign lowecase_tag = tag | downcase
            if lowecase_tag contains preorder_string
              assign preorder_product = true
            endif
            if preorder_product == false and tag contains '_badge:'
              assign custom_badge = tag | remove: '_badge:'
            endif
          endfor
        endif

        if enable_badges
          if product.available
            if preorder_product
              render 'badge', badge: 'preorder', preorder_badge: preorder_string, attributes: badge_attributes
            elsif custom_badge
              render 'badge', badge: 'custom', custom_badge: custom_badge, attributes: badge_attributes
            else
              render 'badge', badge: 'sale', badge_product: product, attributes: badge_attributes
            endif
          else
            render 'badge', badge: 'sold-out', attributes: badge_attributes
          endif
        endif

        assign add_to_cart_text = 'products.product.add_to_cart' | t
        assign add_to_cart_translation_key = 'addToCart'
        assign live_region_text = 'products.general.add_product_to_cart' | t: product: product.title
        if preorder_product
          assign add_to_cart_text = 'products.product.preorder' | t
          assign add_to_cart_translation_key = 'preorder'
          assign live_region_text = 'products.general.preorder_product' | t: product: product.title
        endif
      -%}

      <a href="{{ product.url | within: collection }}" title="{{ product.title }}" class="grid__image grid__image__match {% if settings.product-grid == 'natural' %} image-height--natural{% endif %}" tabindex="-1" data-product-card-link>
        {% if image_crop %}<div class="aspect-ratio {{ image_crop }}">{% endif %}
          {% if product.media.size > 0 %}
            {% assign image = product.featured_media %}
            {% assign img_alt = image.alt %}
            {% if img_alt == product.title %}
              {% assign img_alt = '' %}
            {% endif %}
            {% render 'responsive-image', image: image, alt: img_alt, allow_stretch: image_stretch, blur: false, props: 'data-product-card-image', loading: loading, class: 'block-radius' %}

            {% comment %} Placeholder for swatch images {% endcomment %}
            {% if card_color_swatches_enabled %}
              {% assign swatch_image_attributes = 'data-product-card-swatch-image style="opacity: 0;"' %}
              {% render 'responsive-image', image: image, alt: '', wrapper_class: "product-card__image product-card__image--swatch", allow_stretch: true, blur: false, props: swatch_image_attributes, class: 'block-radius' %}
            {% endif %}

            {% if settings.hover-effect and product.media.size > 1 %}
              {% assign image = product.media[1] %}
              {% assign img_alt = image.alt %}
              {% if img_alt == product.title %}
                {% assign img_alt = '' %}
              {% endif %}
              {% render 'responsive-image', image: image, alt: img_alt, wrapper_class: "product-card__image product-card__image--secondary", allow_stretch: true, blur: false, class: 'block-radius' %}
            {% endif %}
          {% else %}
            {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
            {{ 'product-' | append: current | placeholder_svg_tag: 'icon icon--placeholder grid__image block-radius' }}
          {% endif %}
        {% if image_crop %}</div>{% endif %}
      </a>

      <div class="product-card-image--bottom-wrapper">
        {% if quick_shop_desktop_enabled or quick_shop_mobile_enabled %}
            {% if settings.enable_quick_add and product.available and product.variants.size <= 1 and login_to_order == false %}
              <div class="quick-add-wrapper is-singular">
                {% assign form_id = card_form_id %}
                  {% form 'product', product, id: form_id %}
                    <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
                    {% if settings.cart_type == "drawer" %}
                      <input type="hidden" name="sections" value="cart-drawer" />
                    {% endif %}
                    {% if quick_shop_desktop_enabled %}
                      <button aria-label="{{ live_region_text }}" data-quick-add-button type="submit" class="btn quick-add-button quick-add-button-desktop dynamic-section-button--grid-item--{{ section_id }}" tabindex="0">
                        <span class="quick-add-icon-wrapper quick-add-icon--idle">{% render 'theme-icon', icon: 'add', iconSize: 22 %}</span>
                        <span class="quick-add-icon-wrapper quick-add-icon--loading"><svg viewBox="0 0 25 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="16px" height="16px" class="spin flex-full"><g clip-path="url(#clip0_3605_47041)"><path d="M12.5 23C6.42487 23 1.5 18.0751 1.5 12C1.5 5.92487 6.42487 1 12.5 1C18.5751 1 23.5 5.92487 23.5 12C23.5 15.1767 22.1534 18.0388 20 20.0468" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></g><defs><clipPath id="clip0_3605_47041"><rect width="16" height="16" fill="none" transform="translate(0.5)"/></clipPath></defs></svg></span>
                        {% if settings.add_to_cart_action == 'show_added_message' %}
                          <span class="quick-add-icon-wrapper quick-add-icon--added">{% render 'theme-icon', icon: 'added-success', iconSize: 22 %}</span>
                        {% endif %}
                      </button>
                    {% endif %}
      
                    {% if quick_shop_mobile_enabled %}
                      <button aria-label="{{ live_region_text }}" data-quick-add-button type="submit" class="btn quick-add-button quick-add-button-mobile dynamic-section-button--grid-item--{{ section_id }}" tabindex="0">
                        <span class="quick-add-icon-wrapper quick-add-icon--idle">{% render 'theme-icon', icon: 'add', iconSize: 22 %}</span>
                        <span class="quick-add-icon-wrapper quick-add-icon--loading"><svg viewBox="0 0 25 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="16px" height="16px" class="spin flex-full"><g clip-path="url(#clip0_3605_47041)"><path d="M12.5 23C6.42487 23 1.5 18.0751 1.5 12C1.5 5.92487 6.42487 1 12.5 1C18.5751 1 23.5 5.92487 23.5 12C23.5 15.1767 22.1534 18.0388 20 20.0468" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></g><defs><clipPath id="clip0_3605_47041"><rect width="16" height="16" fill="none" transform="translate(0.5)"/></clipPath></defs></svg></span>
                        {% if settings.add_to_cart_action == 'show_added_message' %}
                          <span class="quick-add-icon-wrapper quick-add-icon--added">{% render 'theme-icon', icon: 'added-success', iconSize: 22 %}</span>
                        {% endif %}
                      </button>
                    {% endif %}

                    <div aria-live="polite" class="sr-only">{{ live_region_text }}</div>
                  {% endform %}
                </div>
              {% else %}
                <div class="quick-add-wrapper">
                  {% if quick_shop_desktop_enabled %}
                    {% render 'quick-view-modal', quick_view_product: product, link_type: 'desktop', section_id: section.id %}
                  {% endif %}

                  {% if quick_shop_mobile_enabled %}
                    {% render 'quick-view-modal', quick_view_product: product, link_type: 'mobile', section_id: section.id %}
                  {% endif %}
                </div>
              {% endif %}
        {% endif %}
      </div>

    </div>

    {% liquid
      assign has_highlight = false
      assign parts = highlight_reference | split: '.'
    %}
  
    {% if parts[0] == 'product' and parts[1] == 'metafields' %}
      {% assign highlight_metafield = product.metafields[parts[2]][parts[3]] %}
  
      {% if highlight_metafield.list? %}
        {% capture highlight_content %}
          {% if highlight_metafield.value != blank %}
            {% if highlight_metafield.type contains '_reference' %}
  
              {% for item in highlight_metafield.value %}
                {% if item.media_type == 'image' %}
                  <div class="product-grid--highlight__list-item">
                    {% render 'responsive-image', image: item, allow_stretch: true %}
                  </div>
                {% elsif item.title %}
                  <div class="product-grid--highlight__list-item">
                    <a href="{{ item.url }}">{{ item.title }}</a>
                  </div>
                {% endif %}
              {% endfor %}
  
            {% else %}
              <ul>
                {% for item in highlight_metafield.value %}
                  <li>
                    {% if highlight_metafield.type == 'list.date' %}
                      {{ item | date: '%B %d, %Y' }}
                    {% elsif highlight_metafield.type == 'list.date_time' %}
                      {{ item | date: '%B %d, %Y' }}, {{ item | date: '%H:%M %P' }}
                    {% elsif highlight_metafield.type == 'list.link' %}
                      <a href="{{ item.url }}">{{ item.text }}</a>
                    {% else %}
                      {{ item }}
                    {% endif %}
                  </li>
                {% endfor %}
              </ul>
  
            {% endif %}
          {% endif %}
        {% endcapture %}
      {% elsif highlight_metafield.value.media_type != 'video' %}
        {% assign highlight_content = highlight_metafield | metafield_tag %}
      {% endif %}
    {% endif %}

    {% liquid
      if highlight_content != blank and show_highlight
        assign has_highlight = true
      endif
  
      if highlight_reference == blank and show_highlight
        assign has_highlight = true
        assign highlight_content = 'general.onboarding.highlight_content' | t
      endif

      assign has_highlight_below_image = false
      if has_highlight and highlight_position == 'below_image'
        assign has_highlight_below_image = true
      endif
    %}

    {% capture highlight_html %}
      {% liquid
        assign has_text_color = false
        if highlight_text_color != 'rgba(0,0,0,0)'
          assign has_text_color = true
          assign highlight_text_color_rgba = 'rgba(' | append: highlight_text_color.rgba | append: ')'
          assign highlight_link_color = 'rgba(' | append: highlight_text_color.rgba | append: ')'
          assign highlight_link_border_color = 'color-mix(in srgb, ' | append: highlight_text_color_rgba | append: ', transparent 50%)'
        endif
      %}
      <div
        class="product-grid--highlight product-grid--highlight--{{ highlight_alignment }} product-grid--highlight--font-size--{{ highlight_font_size }}{% if highlight_background_color != 'rgba(0,0,0,0)' %} product-grid--highlight--has-background{% endif %}{% if highlight_collapsible_tab %}{% if highlight_button_borders %} product-grid--highlight--button-borders{% else %} input-radius{% endif %}{% else %} block-radius{% endif %}{% if has_text_color %} product-grid--highlight--text-color{% endif %}"
        style="{% if has_text_color %}color: {{ highlight_text_color_rgba }}; --link-color: {{ highlight_link_color }}; --link-border-color: {{ highlight_link_border_color }}; --highlight-border-color: {{ highlight_text_color | color_modify: 'alpha', 0.25 }};{% endif %} background-color: {{ highlight_background_color }};"
      >
        {% if highlight_collapsible_tab %}
          {% render 'collapsible-tab-product', heading: highlight_heading, content: highlight_content, open_by_default: false, heading_classes: 'header-font text-link-animated' %}
        {% else %}
          <div class="product-grid--highlight--no-tab">
            <div>
            {% unless highlight_heading == blank %}
              {% render 'text-with-icon', icon: 'none', custom_icon: false, text: highlight_heading, text_classes: 'header-font text-link-animated' %}
            {% endunless %}
            <div class="text-link-animated">
              {{ highlight_content }}
            </div>
            </div>
          </div>
        {% endif %}
      </div>
    {% endcapture %}

    {% if has_highlight_below_image %}
      {{ highlight_html }}
    {% endif %}

    {% if vendor_enabled %}
      <div class="product-grid--vendor {{ vendor_font }}">{{ product.vendor }}</div>
    {% endif %}

    <div class="product-grid--title {{ title_font }}">
      <a{% unless settings.product_card_text_alignment == 'right' %} class="text-truncate--line"{% endunless %} href="{{ product.url | within: collection }}" data-product-card-link>{% if settings.product_card_max_lines > 0 and settings.product_card_text_alignment == 'right' %}{{ product.title | truncate: truncate_value }}{% else %}{{ product.title }}{% endif %}</a>
    </div>

    {% if price_enabled %}
      <div class="product-grid--price {{ price_font }}">
        {%- render 'product-grid-item-price', price_product: product, collection: collection -%}
      </div>
    {% endif %}

    {% liquid
      assign has_highlight_below_price = false
      if has_highlight and highlight_position == 'below_price'
        assign has_highlight_below_price = true
      endif
    %}

    {% if has_highlight_below_price %}
      {{ highlight_html }}
    {% endif %}

    {% if settings.show_product_rating %}
      {% render 'reviews-star-rating',
        rating_product: product,
        star_color: settings.star_rating_color,
        classes: alignment_class,
        star_size: settings.star_size,
        no_reviews_label: settings.no_reviews_label,
        show_rating_as: settings.show_rating_as,
        show_product_rating_if_no_reviews: settings.show_product_rating_if_no_reviews,
        color_scheme: section_color_scheme,
        wrapper_class: 'product-grid--rating'
      %}
    {% endif %}

    {% if card_color_swatches_enabled %}
      {% for option in product.options_with_values %}
        {% render 'card-color-swatch', swatch_product: product, swatch_option: option, hide_out_of_stock_variants: false, show_color_label: show_color_label, option_index: forloop.index %}
      {% endfor %}
    {% endif %}
  </div>

  {% liquid
    assign has_highlight_below_swatches = false
    if has_highlight and highlight_position == 'bottom'
      assign has_highlight_below_swatches = true
    endif

    assign has_highlight_bottom = false
    if has_highlight_below_swatches
      assign has_highlight_bottom = true
    endif

    assign has_quick_shop_block = false
  %}

  {% if has_highlight_bottom or has_quick_shop_block %}
    <div class="product-grid--footer">

      {% if has_highlight_below_swatches %}
        {{ highlight_html }}
      {% endif %}


    </div>
  {% endif %}
</product-card>
